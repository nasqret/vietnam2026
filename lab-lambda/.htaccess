# Ensure HTTPS behind the faculty TLS-terminating reverse proxy.
# Loop-safe: only redirects when the proxy reports the original scheme was http
# (X-Forwarded-Proto). If the header is absent or https, this rule does nothing.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Correct MIME for WebAssembly (enables streaming compilation of self-hosted Pyodide)
<IfModule mod_mime.c>
  AddType application/wasm .wasm
  AddType font/woff2 .woff2
</IfModule>
